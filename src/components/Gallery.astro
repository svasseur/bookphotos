---
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Photo {
	src: ImageMetadata;
	alt: string;
	caption?: string;
}

interface Props {
	photos: Photo[];
}

const { photos } = Astro.props;

const fullSizePhotos = await Promise.all(
	photos.map(async (photo) => {
		const optimized = await getImage({ src: photo.src, width: 1920 });
		return { src: optimized.src, alt: photo.alt, caption: photo.caption ?? '' };
	}),
);

const galleryData = JSON.stringify(fullSizePhotos).replace(/</g, '\\u003c');
---

<div class="gallery">
	<ul class="grid" role="list">
		{
			photos.map((photo, index) => (
				<li>
					<button
						class="thumb"
						data-index={index}
						aria-label={`Agrandir la photo ${index + 1}${photo.caption ? ` — ${photo.caption}` : ''}`}
					>
						<Image src={photo.src} alt={photo.alt} width={640} loading="lazy" decoding="async" />
					</button>
				</li>
			))
		}
	</ul>
</div>

<div class="lightbox" id="lightbox">
	<button class="lightbox-close" id="lightbox-close" aria-label="Fermer">&times;</button>
	<button class="lightbox-nav lightbox-prev" id="lightbox-prev" aria-label="Photo précédente">&lsaquo;</button>
	<figure class="lightbox-figure">
		<img class="lightbox-image" id="lightbox-image" alt="" />
		<figcaption id="lightbox-caption"></figcaption>
	</figure>
	<button class="lightbox-nav lightbox-next" id="lightbox-next" aria-label="Photo suivante">&rsaquo;</button>
</div>

<script type="application/json" id="gallery-data" set:html={galleryData} is:inline />

<style>
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 0.5rem;
		margin: 0;
		padding: 0 1.5rem 3rem;
		list-style: none;
	}

	.thumb {
		display: block;
		width: 100%;
		aspect-ratio: 4 / 3;
		overflow: hidden;
		background: #0a0a0a;
	}

	.thumb :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition:
			transform 0.6s ease,
			opacity 0.6s ease;
	}

	.thumb:hover :global(img),
	.thumb:focus-visible :global(img) {
		transform: scale(1.03);
		opacity: 0.9;
	}

	.lightbox {
		position: fixed;
		inset: 0;
		z-index: 100;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(0, 0, 0, 0.96);
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transition:
			opacity 0.5s ease,
			visibility 0s linear 0.5s;
	}

	.lightbox.is-open {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
		transition: opacity 0.5s ease;
	}

	.lightbox-figure {
		margin: 0;
		max-width: min(92vw, 1400px);
		max-height: 90vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.75rem;
		transform: scale(0.96);
		transition: transform 0.5s ease;
	}

	.lightbox.is-open .lightbox-figure {
		transform: scale(1);
	}

	.lightbox-image {
		max-width: 100%;
		max-height: 80vh;
		object-fit: contain;
		opacity: 1;
		transition: opacity 0.25s ease;
	}

	.lightbox-image.is-fading {
		opacity: 0;
	}

	.lightbox-figure figcaption {
		color: var(--fg-muted);
		font-size: 0.9rem;
		min-height: 1.2em;
	}

	.lightbox-close,
	.lightbox-nav {
		position: absolute;
		color: var(--fg);
		font-size: 2rem;
		line-height: 1;
		padding: 0.5rem 1rem;
	}

	.lightbox-close {
		top: 1rem;
		right: 1rem;
	}

	.lightbox-prev {
		left: 0.5rem;
		top: 50%;
		transform: translateY(-50%);
	}

	.lightbox-next {
		right: 0.5rem;
		top: 50%;
		transform: translateY(-50%);
	}

	.lightbox-close:hover,
	.lightbox-nav:hover {
		color: var(--fg-muted);
	}
</style>

<script>
	function initGallery() {
		const dataEl = document.getElementById('gallery-data');
		const lightbox = document.getElementById('lightbox');
		const imageEl = document.getElementById('lightbox-image') as HTMLImageElement | null;
		const captionEl = document.getElementById('lightbox-caption');
		if (!dataEl || !lightbox || !imageEl || !captionEl) return;

		const photos = JSON.parse(dataEl.textContent || '[]') as Array<{
			src: string;
			alt: string;
			caption: string;
		}>;
		const closeBtn = document.getElementById('lightbox-close');
		const prevBtn = document.getElementById('lightbox-prev');
		const nextBtn = document.getElementById('lightbox-next');
		const thumbs = document.querySelectorAll<HTMLButtonElement>('.thumb');

		let currentIndex = 0;
		let fadeTimeout: ReturnType<typeof setTimeout> | undefined;

		function render() {
			const photo = photos[currentIndex];
			if (!imageEl || !captionEl) return;
			imageEl.src = photo.src;
			imageEl.alt = photo.alt;
			captionEl.textContent = photo.caption;
		}

		function show(index: number, { fade = true } = {}) {
			currentIndex = (index + photos.length) % photos.length;
			if (!fade || !imageEl) {
				render();
				return;
			}
			clearTimeout(fadeTimeout);
			imageEl.classList.add('is-fading');
			fadeTimeout = setTimeout(() => {
				render();
				imageEl?.classList.remove('is-fading');
			}, 200);
		}

		function open(index: number) {
			show(index, { fade: false });
			lightbox?.classList.add('is-open');
			document.body.style.overflow = 'hidden';
		}

		function close() {
			lightbox?.classList.remove('is-open');
			document.body.style.overflow = '';
		}

		thumbs.forEach((thumb) => {
			thumb.addEventListener('click', () => open(Number(thumb.dataset.index)));
		});

		closeBtn?.addEventListener('click', close);
		prevBtn?.addEventListener('click', () => show(currentIndex - 1));
		nextBtn?.addEventListener('click', () => show(currentIndex + 1));
		lightbox?.addEventListener('click', (event) => {
			if (event.target === lightbox) close();
		});

		document.addEventListener('keydown', (event) => {
			if (!lightbox?.classList.contains('is-open')) return;
			if (event.key === 'Escape') close();
			if (event.key === 'ArrowLeft') show(currentIndex - 1);
			if (event.key === 'ArrowRight') show(currentIndex + 1);
		});
	}

	document.addEventListener('astro:page-load', initGallery);
</script>
