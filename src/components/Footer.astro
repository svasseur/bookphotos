---
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<p>&copy; {year} Sébastien Vasseur</p>
	<a
		class="social-link"
		href="https://www.instagram.com/svasseur"
		target="_blank"
		rel="noopener noreferrer"
		aria-label="Instagram"
	>
		<svg
			viewBox="0 0 24 24"
			width="20"
			height="20"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
		>
			<rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
			<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
			<line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
		</svg>
	</a>
	<a
		class="social-link"
		href="https://sebastienvasseur.myportfolio.com/"
		target="_blank"
		rel="noopener noreferrer"
		aria-label="Portfolio Adobe"
	>
		<svg
			viewBox="0 0 24 24"
			width="20"
			height="20"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
		>
			<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
			<polyline points="15 3 21 3 21 9"></polyline>
			<line x1="10" y1="14" x2="21" y2="3"></line>
		</svg>
	</a>
</footer>

<style>
	.site-footer {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		padding: 3rem 1.5rem 2rem;
		color: var(--fg-faint);
		font-size: 0.85rem;
	}

	.site-footer p {
		margin: 0;
	}

	.social-link {
		display: inline-flex;
		color: var(--fg-faint);
		transition: color 0.2s ease;
	}

	.social-link:hover {
		color: var(--fg);
	}
</style>
