---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ChapterCard from '../components/ChapterCard.astro';

const chapters = (await getCollection('chapters')).sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Sébastien Vasseur — Photographies">
	<section class="hero">
		<h1>Photographies</h1>
	</section>

	<section class="chapters-grid">
		{chapters.map((chapter, index) => <ChapterCard chapter={chapter} index={index} />)}
	</section>
</Layout>

<style>
	.hero {
		padding: 3rem 1.5rem 2.5rem;
		text-align: center;
	}

	.hero h1 {
		margin: 0;
		color: var(--fg-muted);
		text-transform: uppercase;
		letter-spacing: 0.2em;
		font-size: 0.85rem;
		font-family: inherit;
		font-weight: 400;
	}

	.chapters-grid {
		display: flex;
		gap: 1px;
		padding: 0 1.5rem 3rem;
		overflow-x: auto;
		scroll-snap-type: x proximity;
		scrollbar-color: var(--fg-faint) transparent;
	}

	.chapters-grid :global(.chapter-card) {
		flex: 0 0 clamp(390px, 48vw, 570px);
		scroll-snap-align: start;
	}
</style>
